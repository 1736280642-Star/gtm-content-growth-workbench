    "worker:import-log": "node workers/import-demo-log.mjs",
    "worker:import-channel-metrics": "node workers/import-channel-metrics.mjs",
    "worker:run-pipeline": "node workers/run-pipeline.mjs",
    "worker:schedule-pipeline": "node workers/schedule-pipeline.mjs"
