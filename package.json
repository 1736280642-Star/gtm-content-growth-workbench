    "capture-runner:start": "node capture-runner/src/server.mjs",
    "test:v5-observation": "node --no-warnings --experimental-transform-types --loader ./workers/typescript-loader.mjs --test scripts/v5-observation-review.test.mjs",
    "test:v5-monthly-production": "node --test scripts/v5-monthly-production.test.mjs",
    "test:v5-article-types": "node --no-warnings --experimental-transform-types --loader ./workers/typescript-loader.mjs --test scripts/v5-article-types.test.mjs",
